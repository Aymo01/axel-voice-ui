# Axel backend base URL
VITE_AXEL_API_URL=https://axle-production-3d97.up.railway.app

# Picovoice Porcupine wake-word detection
# Get a free AccessKey at https://console.picovoice.ai/
VITE_PICOVOICE_ACCESS_KEY=

# Custom "Hey Axel" wake word: train it at https://console.picovoice.ai/
# then export the WASM (.ppn) file, drop it in /public, and point to it here.
VITE_PORCUPINE_KEYWORD_PATH=/Hey-Axel_en_wasm_v3_0_0.ppn
VITE_PORCUPINE_KEYWORD_LABEL=Hey Axel

# Optional: until your custom "Hey Axel" model is trained, you can test with a
# free built-in keyword instead (Alexa, Americano, Blueberry, Bumblebee, Computer,
# Grapefruit, Grasshopper, "Hey Google", "Hey Siri", Jarvis, "Okay Google",
# Picovoice, Porcupine, Terminator). Leave VITE_PORCUPINE_KEYWORD_PATH empty to use this.
VITE_PORCUPINE_BUILTIN_KEYWORD=Computer

# Porcupine model params file, also downloaded from the Picovoice console
# (or copied from node_modules/@picovoice/porcupine-web/lib/porcupine_params.pv)
VITE_PORCUPINE_MODEL_PATH=/porcupine_params.pv
